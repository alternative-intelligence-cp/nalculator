[project]
name = "nalculator"
version = "0.0.0"

[target.nalculator]
type = "binary"
sources = ["src/main.npk"]
deps = []
flags = ["-O2"]
link_libraries = ["gtk-4", "gio-2.0", "gobject-2.0", "glib-2.0", "m"]
link_paths = []

[target.test-nalculator]
type = "binary"
sources = ["tests/test_main.npk"]
deps = []
flags = []
link_libraries = ["gtk-4", "gio-2.0", "gobject-2.0", "glib-2.0", "m"]
link_paths = []
